{
    // Контракт проекта: IDE запускается ТОЛЬКО через Dev Container (Reopen in Container).
    // Все инструменты вызываются внутри контейнера напрямую, никаких host→container-прокси.
    "[php]": {
        "editor.defaultFormatter": "junstyle.php-cs-fixer"
    },
    // PHPUnit: прямой php + bin/phpunit. Хвост `-d xdebug.client_host=host.docker.internal`
    // перебивает DEVSENSE-овский хардкод 127.0.0.1 в debug-режиме (last-wins).
    "phpunit.command": "\"${php}\" ${phpargs} -d xdebug.client_host=host.docker.internal \"${phpunit}\" ${phpunitargs}",
    // PHP CS (major): обёртка делает `cd` в корень проекта перед запуском бинаря.
    // Расширение junstyle запускает бинарь из папки форматируемого файла, а CS
    // Fixer читает composer.json только из cwd (без walk-up) — без обёртки сыпятся
    // warning'и про minimum PHP version.
    "php-cs-fixer.executablePath": "${workspaceFolder}/.vscode/php-cs-wrapper.sh",
    // cs-check и psalm не имеют watch-режима: назначаем запуск на folderOpen (в
    // .vscode/tasks.json) и на каждое сохранение .php-файла.
    "triggerTaskOnSave.tasks": {
        "PHP CS (major)": [
            "**/*.php"
        ],
        "PHP CS (minor)": [
            "**/*.php"
        ],
        "Psalm": [
            "**/*.php"
        ]
    },
    // Psalm тащит dictionaries (sig-карты PHP-функций) по несколько мегабайт —
    // Intelephense пытается их индексировать и сжирает память.
    "intelephense.files.exclude": [
        "**/vendor/vimeo/psalm/dictionaries/**"
    ],
    "cSpell.words": [
        "Mailpit"
    ],
    "prettier.configPath": ".vscode/.prettierrc"
}
